{
    "name": "mbap",
    "displayName": "M&B: Warband API",
    "description": "Mount & Blade: Warband language support, code formatter, and dynamic IntelliSense for Microsoft Visual Studio Code by Azremen and Sart",
    "publisher": "Azremen",
    "version": "0.3.0",
    "homepage": "https://github.com/Azremen/MB-Warband-API-VSC/blob/main/README.md",
    "engines": {
        "vscode": "^1.95.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Azremen/MB-Warband-API-VSC.git"
    },
    "keywords": [
        "warband",
        "mount and blade",
        "modding",
        "script",
        "snippet"
    ],
    "categories": [
        "Programming Languages",
        "Formatters",
        "Snippets"
    ],
    "activationEvents": [
        "onLanguage:python"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "mbap.formatWarbandScript",
                "title": "Format Warband Script Language Code"
            }
        ],
        "snippets": [
            {
                "language": "python",
                "path": "./snippets/mbap.code-snippets"
            }
        ],
        "configuration": {
            "title": "Warband Script Language Formatter",
            "properties": {
                "mbap.lineLength": {
                    "type": "number",
                    "default": 2000,
                    "description": "Maximum line length for the formatter before wrapping."
                },
                "mbap.indentation": {
                    "type": "string",
                    "enum": [
                        "tabs",
                        "spaces"
                    ],
                    "default": "spaces",
                    "description": "Indentation style for Warband Script Language Formatter."
                },
                "mbap.tabSize": {
                    "type": "number",
                    "default": 4,
                    "description": "Number of spaces or tabs to use for indentation."
                }
            }
        }
    }
}